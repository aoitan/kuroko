FROM node:22-bookworm-slim AS node

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOME=/home/dev \
    UV_CACHE_DIR=/var/cache/uv \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/var/cache/uv/project-env

COPY --from=ghcr.io/astral-sh/uv:0.8.22 /uv /uvx /bin/
COPY --from=node /usr/local/ /usr/local/
COPY docker/dev-entrypoint.sh /usr/local/bin/dev-entrypoint.sh

RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates \
    && npm install -g @google/gemini-cli @openai/codex @github/copilot \
    && chmod +x /usr/local/bin/dev-entrypoint.sh \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /workspace /home/dev /var/cache/uv /var/cache/uv/project-env \
    && chown -R 1000:1000 /workspace /home/dev \
    && chmod 1777 /var/cache/uv /var/cache/uv/project-env

WORKDIR /workspace

CMD ["sh"]
